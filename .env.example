# BuildMatch — Environment Variables
# ============================================================
# CARA PAKAI:
#   1. Copy file ini, rename jadi ".env"  (jangan di-commit!)
#   2. Isi nilai di bawah dengan credentials Supabase project kamu
#   3. Set environment variables sebelum run:
#      - Windows PowerShell : $env:SUPABASE_URL="https://xxx.supabase.co"
#      - Windows CMD        : set SUPABASE_URL=https://xxx.supabase.co
#      - macOS/Linux        : export SUPABASE_URL=https://xxx.supabase.co
#
# Atau gunakan extension "DotENV" di VS Code dan konfigurasi
# di launch.json agar variabel di-load otomatis.
# ============================================================

SUPABASE_URL=https://eboseqlzrfabtiurwjpl.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
